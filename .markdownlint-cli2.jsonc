{
  // Structural checks on; only line-length relaxed (tables and command
  // examples). Historical corpora are excluded below, not rule-exempted.
  "config": {
    "default": true,
    "MD013": false
  },
  "ignores": [
    "planning/**",
    "metrics/**",
    "rldyourterm/**",
    "CHANGELOG.md",
    "node_modules/**"
  ]
}
